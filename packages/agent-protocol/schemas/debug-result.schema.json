{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "debug-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "root_cause", "fix_summary", "tests_run"],
  "properties": {
    "status": { "type": "string", "enum": ["fixed", "not_fixed", "inconclusive"] },
    "root_cause": { "type": "string", "minLength": 1 },
    "fix_summary": { "type": "string", "minLength": 1 },
    "tests_run": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "remaining_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
